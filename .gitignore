# Raw corpus and built database — never committed (evaluators get data separately; DB is rebuilt)
# Root-anchored so tests/fixtures/data/ (tiny committed fixtures) stays tracked.
/data/
/db/
*.duckdb
*.duckdb.wal
tests/tmp/

# Generated intermediates (industry-map rosters, other tool outputs) — disposable,
# rebuilt from the DB; written to a repo-root out/, never into skills/, never committed.
/out/

# Python
__pycache__/
*.pyc
.venv/
venv/

# OS noise
Thumbs.db
.DS_Store
