# Raw corpus and built database — never committed (evaluators get data separately; DB is rebuilt)
# Root-anchored so tests/fixtures/data/ (tiny committed fixtures) stays tracked.
/data/
/db/
*.duckdb
*.duckdb.wal
tests/tmp/

# Tool outputs (rosters, review packages, API caches) live in repo-root out/ and ARE
# committed (Rob, 2026-07-11 — reversal of the 4cae303 gitignored-out/ convention):
# packages are review artifacts, caches are the citeable evidence. Still never write
# generated artifacts into skills/. The FEC API key file must NEVER be committed,
# whether or not it currently exists:
/out/.fec_api_key

# Python
__pycache__/
*.pyc
.venv/
venv/

# OS noise
Thumbs.db
.DS_Store

# Local experiments (bake-offs, prototypes) — never submitted; may hold venvs/model caches
scratch/

# R skill loader cache (mirrors ChrisCioffi/agentic_investigation .gitignore)
skills/*/.cache/
